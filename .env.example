# AI Providers — Core
GOOGLE_AI_API_KEY=           # Gemini Flash (fallback, gratuit) — console.cloud.google.com
GROQ_API_KEY=                # Groq Llama 4 Scout (fallback rapid, gratuit) — console.groq.com
MISTRAL_API_KEY=             # Mistral Small 3 (fallback european, 1B tokeni/luna) — console.mistral.ai
CEREBRAS_API_KEY=            # Cerebras Qwen 3 235B (fallback, gratuit, 1M tokeni/zi) — cloud.cerebras.ai
SYNTHESIS_MODE=claude_code   # "claude_code" (default) | "autonomous" (Groq/Gemini/Cerebras)

# AI Providers — F7 Extensions (optionale, adauga treptat)
DEEPSEEK_API_KEY=            # DeepSeek R1 reasoning financiar — platform.deepseek.com ($2 credit gratuit)
BRAVE_API_KEY=               # Brave Search — index propriu, 2000 req/luna GRATUIT, fara card — api.search.brave.com/register
JINA_API_KEY=                # Jina Reader scraping curat (optional, merge si fara) — jina.ai/reader/
COHERE_API_KEY=              # Cohere Embed+Rerank RAG — dashboard.cohere.com (1000 req/luna gratuit)
XAI_API_KEY=                 # xAI Grok live X/Twitter — console.x.ai (ATENTIE: data sharing!)
OPENROUTER_API_KEY=          # OpenRouter gateway 100+ modele — openrouter.ai ($1 credit gratuit)

# Web Search
TAVILY_API_KEY=              # Search verificat cu surse (1000 req/luna gratuit)

# ONRC (openapi.ro)
OPENAPI_RO_KEY=              # Date ONRC structurate (100 req/luna gratuit, https://openapi.ro)

# Notificari
TELEGRAM_BOT_TOKEN=          # Bot token de la @BotFather
TELEGRAM_CHAT_ID=            # Chat ID personal

# Email
GMAIL_USER=                  # adresa gmail
GMAIL_APP_PASSWORD=          # App Password Gmail (nu parola contului!)

# Securitate
RIS_API_KEY=                 # Optional: protejeaza /api/ cu X-RIS-Key header
APP_SECRET_KEY=change-me-to-random-string
DATABASE_PATH=./data/ris.db
CHECKPOINT_DB_PATH=./data/checkpoints.db
OUTPUTS_DIR=./outputs/
LOG_LEVEL=INFO
BACKEND_PORT=8001
FRONTEND_PORT=5173

# Rate limiting
MAX_CONCURRENT_JOBS=2
REQUEST_DELAY_GOV=2          # secunde intre cereri pe .gov.ro
REQUEST_DELAY_WEB=3          # secunde intre cereri web scraping

# Tavily quota
TAVILY_MONTHLY_QUOTA=1000
TAVILY_WARN_AT=800
